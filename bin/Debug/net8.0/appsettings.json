{
  "Environment": "QA",
  "ApiUrls": {
    "AuthBaseUrl": "https://testRovicare.b2clogin.com/",
    "ApiBaseUrl": "https://apim-rc-test.azure-api.net/main/api/"
  },
  "BaseUrlTypes": {
    "Auth": "AuthBaseUrl",
    "Api": "ApiBaseUrl"
  },
  "FeatureBaseUrlMap": {
    "User API Testing": "Api",
    "Login": "Auth",
    "Login and Logout": "Auth",
    "Access Token Refresh": "Api",
    "TokenRefresh": "Api"
  },
  "Timeout": 30000,
